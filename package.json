{
  "name": "upr-desktop",
  "productName": "Universal Presenter Remote",
  "version": "1.3.2",
  "description": "Control your presentations from any platform.",
  "homepage": "https://universalpresenterremote.com",
  "license": "MIT",
  "type": "commonjs",
  "main": "./out/main/index.js",
  "author": {
    "name": "Brendan Boyle",
    "email": "brendan@dbztech.com",
    "url": "https://github.com/brendancboyle"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brendancboyle/upr-desktop.git"
  },
  "bugs": {
    "url": "https://github.com/brendancboyle/upr-desktop/issues"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:bridge": "UPR_MIGRATION_NOTICE=true electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "package": "npm run build && electron-builder --publish never",
    "release": "npm run build && electron-builder --publish always"
  },
  "dependencies": {
    "@sentry/electron": "7.13.0",
    "electron-log": "5.4.4",
    "electron-updater": "6.8.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "send-keys-native": "file:../send-keys-native",
    "socket.io-client": "2.5.0"
  },
  "devDependencies": {
    "@types/node": "25.9.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "42.3.3",
    "electron-builder": "26.15.1",
    "electron-vite": "5.0.0",
    "typescript": "6.0.3",
    "vite": "7.3.5"
  }
}
